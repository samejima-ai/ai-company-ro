# ヤジ 環境変数（形だけ。実値は .env に置き、コミットしない）

# Discord bot トークン（未設定なら接続せず scaffold スモークのみ動く）
DISCORD_TOKEN=

# 応答対象の大喜利チャンネル ID（カンマ区切り）。空ならメンション/リプライのみ反応
OOGIRI_CHANNEL_IDS=

# 記憶ストア（SQLite ファイルパス）
DB_PATH=data/oogiri.db

# ペルソナ正本（system prompt の在処）
PERSONA_PATH=personas/riko_system_prompt.md

# モデルルーター（プロバイダ非固定。決定時にベンチマークして差し替え）
MODEL_FAST=
MODEL_HEAVY=
LLM_API_KEY=
