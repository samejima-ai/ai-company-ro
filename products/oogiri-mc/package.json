{
  "name": "oogiri-mc",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ヤジ — テキスト対話で投げ銭を稼ぐ毒舌大喜利MCボット（Discord, MVP Phase 0）",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "eval": "tsx src/eval.ts",
    "build": "tsup src/index.ts --format esm --target node20 --out-dir dist --clean",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
